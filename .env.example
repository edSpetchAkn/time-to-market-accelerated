# ─── Value Framework POC — Time to Market Accelerated ────────────────────────
# Copy this file to .env and set values for your instance.

# Enable verbose console.debug output at each calculation step.
# VITE_DEBUG_MODE=true

# Products per page (max 100).
# VITE_PRODUCTS_PAGE_SIZE=100

# Preferred channel code for the completeness metric.
# Falls back to the first channel discovered in the data.
# VITE_DEFAULT_CHANNEL=ecommerce

# Base URL of your Akeneo PIM instance (no trailing slash).
# Required for the Rules Engine metric (external.call gateway).
# VITE_PIM_BASE_URL=https://your-instance.akeneo.com

# Connected App credentials code used for external.call() requests.
# Required for the Rules Engine metric.
# VITE_RULES_CREDENTIALS_CODE=your_credentials_code
